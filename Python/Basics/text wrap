# ---------------- HackerRank Text Wrap Problem ----------------
# Question:
# Given a string and max width,
# print the string in multiple lines
# where each line contains max_width characters.

def wrap(string, max_width):

    count = 0
    result = ""

    for i in range(len(string)):

        if count < max_width:
            result += string[i]
            count += 1

        elif count == max_width:
            result += "\n"
            count = 0
            result += string[i]
            count += 1

    return result
