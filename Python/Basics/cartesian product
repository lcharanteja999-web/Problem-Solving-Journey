# ---------------- Cartesian Product ----------------
# Question:
# Given two lists A and B, print their Cartesian Product.
#
# Example:
# Input:
# A = [1, 2]
# B = [3, 4]
#
# Output:
# (1, 3) (1, 4) (2, 3) (2, 4)

# Read input
a = list(map(int, input().split()))
b = list(map(int, input().split()))

for i in a:
    for j in b:
        print((i, j), end=" ")
